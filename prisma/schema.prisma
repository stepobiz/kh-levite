generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}


model IotDevice {
  id         Int                 @id @default(autoincrement())
  deviceName       String?
  macAddress String?             @unique @map("mac_address")
  ipAddress  String             @map("ip_address")
  driver   String?
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  components IotDeviceComponent[]

  @@map("iot_device")
}

model IotDeviceComponent {
  id                  Int               @id @default(autoincrement())
  deviceId            Int               @map("device_id")
  componentName       String?           @map("component_name")
  hardwareIndex       Int               @map("hardware_index")
  hardwareAddress     String?           @map("hardware_address")
  nextValue           String?           @map("next_value")
  nextValueUpdatedAt  DateTime?         @map("next_value_updated_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  device              IotDevice         @relation(fields: [deviceId], references: [id])
  telemetryLogs       IotTelemetryLog[]
  auenNode            AuenNode?

  @@index([deviceId])
  @@map("iot_device_component")
}

model IotTelemetryLog {
  id Int @id @default(autoincrement())
  componentId Int              @map("component_id")
  value      String
  direction  String
  createdAt  DateTime          @default(now()) @map("created_at")
  component  IotDeviceComponent @relation(fields: [componentId], references: [id])

  @@index([componentId, createdAt])
  @@map("iot_telemetry_log")
}

// --- AutoEngine ---

enum AuenNodeCategory {
  in_sensor
  node_manual_target
  node_manual_value_by_url
  proxy_mirror
  proxy_inverter
  fake
  out_logic_or
  out_logic_and
  out_thermostat
}

model AuenNodeType {
  id        Int              @id @default(autoincrement())
  name      String
  iconSlug  String?          @map("icon_slug")
  category  AuenNodeCategory
  valueType String           @default("boolean") @map("value_type")
  isSystem  Boolean          @default(false) @map("is_system")
  nodes              AuenNode[]
  nodeTypeAttributes AuenNodeTypeAttribute[]

  @@unique([category, valueType])
  @@map("auen_node_type")
}

model AuenNode {
  id                    Int       @id @default(autoincrement())
  code                  String?
  description           String?
  typeId                Int       @map("type_id")
  parentId              Int?      @map("parent_id")
  iotComponentId        Int?      @unique @map("iot_component_id")
  isLogical             Boolean   @default(false) @map("is_logical")
  order                 Int       @default(0) @map("node_order")
  desiredValue          String    @default("0") @map("desired_value")
  desiredValueUpdatedAt DateTime? @map("desired_value_updated_at")
  actualValue           String    @default("0") @map("actual_value")
  actualValueUpdatedAt  DateTime? @map("actual_value_updated_at")

  type         AuenNodeType        @relation(fields: [typeId], references: [id])
  parent       AuenNode?           @relation("AuenNodeChildren", fields: [parentId], references: [id])
  children     AuenNode[]          @relation("AuenNodeChildren")
  attributes   AuenNodeAttribute[]
  tags         AuenNodeTag[]
  iotComponent IotDeviceComponent? @relation(fields: [iotComponentId], references: [id])

  @@index([parentId])
  @@map("auen_node")
}

model AuenTag {
  id    Int           @id @default(autoincrement())
  name  String        @unique
  nodes AuenNodeTag[]

  @@map("auen_tag")
}

model AuenNodeTag {
  nodeId Int      @map("node_id")
  tagId  Int      @map("tag_id")
  node   AuenNode @relation(fields: [nodeId], references: [id])
  tag    AuenTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([nodeId, tagId])
  @@map("auen_node_tag")
}

model AuenAttributeType {
  id             Int                 @id @default(autoincrement())
  code           String              @unique
  description    String?
  dataType       String              @map("data_type")
  isSystem       Boolean             @default(false) @map("is_system")
  nodeAttributes     AuenNodeAttribute[]
  nodeTypeAttributes AuenNodeTypeAttribute[]

  @@map("auen_attribute_type")
}

model AuenNodeAttribute {
  nodeId      Int    @map("node_id")
  attributeId Int    @map("attribute_id")
  value       String

  node      AuenNode          @relation(fields: [nodeId], references: [id])
  attribute AuenAttributeType @relation(fields: [attributeId], references: [id])

  @@id([nodeId, attributeId])
  @@map("auen_node_attribute")
}

model AuenNodeTypeAttribute {
  nodeTypeId  Int     @map("node_type_id")
  attributeId Int     @map("attribute_id")
  isRequired  Boolean @default(false) @map("is_required")

  nodeType  AuenNodeType      @relation(fields: [nodeTypeId], references: [id])
  attribute AuenAttributeType @relation(fields: [attributeId], references: [id])

  @@id([nodeTypeId, attributeId])
  @@map("auen_node_type_attribute")
}

// --- Infrastructure ---

model SysProcessLog {
  id          Int      @id @default(autoincrement())
  processName String   @map("process_name")
  startedAt   DateTime @map("started_at")
  endedAt     DateTime @map("ended_at")
  durationMs  Int      @map("duration_ms")
  itemCount   Int      @map("item_count")
  status      String
  errorMsg    String?  @map("error_msg")

  @@index([processName])
  @@index([startedAt])
  @@map("sys_process_log")
}

// --- Configuration ---

enum CfgValueType {
  integer
  float
  boolean
  text
}

model CfgSection {
  id             Int                @id @default(autoincrement())
  code           String             @unique
  name           String
  configurations CfgConfiguration[]

  @@map("cfg_section")
}

model CfgConfiguration {
  code        String       @id
  name        String
  description String?
  sectionId   Int?         @map("section_id")
  section     CfgSection?  @relation(fields: [sectionId], references: [id])
  dataType    CfgValueType @map("data_type")
  isSystem    Boolean      @default(false) @map("is_system")
  valInt      Int?         @map("val_int")
  valFloat    Float?       @map("val_float")
  valBool     Boolean?     @map("val_bool")
  valText     String?      @map("val_text")

  @@map("cfg_configuration")
}